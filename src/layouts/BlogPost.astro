---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/*
			 * 页面布局 - 参考 Zenn 的分层背景 + 卡片化文章
			 * 外层: --color-bg-outer (浅灰)
			 * 内层: --color-bg-inner (白色卡片)
			 */
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			/* 外层容器 - 浅灰背景 */
			.article-outer {
				background: var(--color-bg-outer);
				padding: 0 0 4rem;
			}

			/* 文章头部 - 大留白，居中标题，浅灰背景 */
			.article-header {
				max-width: 100%;
				background: var(--color-bg-outer);
				border-top: 1px solid var(--color-border-lighter);
			}
			.article-header-inner {
				max-width: 820px;
				margin: 0 auto;
				padding: 3.8rem 40px 3.5rem;
				text-align: center;
				line-height: 1.4;
			}
			.article-header-inner h1 {
				display: inline-block;
				max-width: 780px;
				font-size: 2em;
				font-weight: 700;
				line-height: 1.4;
				margin: 0 auto 0.8em;
				color: rgb(var(--black));
				text-align: left;
			}
			.article-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				font-size: 0.88em;
				color: var(--color-text-subtle);
			}
			.last-updated-on {
				font-style: italic;
			}

			/* 文章卡片 - 白色背景 + 边框 + 圆角 */
			.article-card {
				max-width: 820px;
				background: var(--color-bg-inner);
				border: 1px solid var(--color-border-lighter);
				border-radius: 4px;
				padding: 2.5rem 40px;
				font-size: 16px;
			}

			/* 双栏布局：文章 + TOC 侧边栏 */
			.columns-container {
				display: flex;
				justify-content: center;
				gap: 1.5rem;
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 40px;
			}

			/* 文章主体区域 */
			.content-column {
				flex: 1;
				max-width: 820px;
				min-width: 0;
			}

			/* TOC 侧边栏 */
			.sidebar-column {
				width: 260px;
				flex-shrink: 0;
			}

			@media (max-width: 1100px) {
				.sidebar-column {
					display: none;
				}
				.columns-container {
					padding: 0;
				}
			}

			/* 头图 */
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}

			/*
			 * 文章正文 (.prose)
			 * 参考 Zenn .znc 的排版：line-height 1.9、段落间距、标题层级
			 */
			.prose {
				max-width: 100%;
				line-height: 1.9;
				color: var(--color-text-body);
			}

			/* 段落间距 - Zenn: p+p { margin-top: 1.5em } */
			.prose :global(p + p) {
				margin-top: 1.5em;
			}
			.prose :global(p) {
				margin-bottom: 0;
				margin-top: 0;
			}

			/* 标题锚点滚动偏移 - 点击 TOC 时标题不贴顶 */
			.prose :global(h1[id]),
			.prose :global(h2[id]),
			.prose :global(h3[id]),
			.prose :global(h4[id]),
			.prose :global(h5[id]),
			.prose :global(h6[id]) {
				scroll-margin-top: 4rem;
			}

			/* 标题层级 - 参考 Zenn .znc h1-h6 */
			.prose :global(h1),
			.prose :global(h2) {
				margin-top: 2.3em;
				margin-bottom: 1.1rem;
				padding-bottom: 0.3em;
				border-bottom: 1px solid var(--color-border);
			}
			.prose :global(h1) {
				font-size: 1.7em;
				padding-bottom: 0.2em;
			}
			.prose :global(h2) {
				font-size: 1.5em;
			}
			.prose :global(h3),
			.prose :global(h4),
			.prose :global(h5),
			.prose :global(h6) {
				margin-top: 2.25em;
				margin-bottom: 0.5em;
			}
			.prose :global(h3) { font-size: 1.3em; }
			.prose :global(h4) { font-size: 1.1em; }
			.prose :global(h5) { font-size: 1em; }
			.prose :global(h6) { font-size: 0.9em; }

			/* 标题后紧跟段落时缩小间距 - Zenn: h*+p { margin-top: .3em } */
			.prose :global(h1 + p),
			.prose :global(h2 + p),
			.prose :global(h3 + p),
			.prose :global(h4 + p),
			.prose :global(h5 + p),
			.prose :global(h6 + p) {
				margin-top: 0.3em;
			}

			/* 首个子元素无顶部间距 */
			.prose :global(> :first-child) {
				margin-top: 0;
			}

			/* 链接 - Zenn 风格 */
			.prose :global(a) {
				color: var(--color-text-link);
				text-decoration: none;
			}
			.prose :global(a:hover) {
				text-decoration: underline;
			}

			/* 图片 - 参考 Zenn .znc img */
			.prose :global(img) {
				margin: 1.5rem auto;
				display: block;
				max-width: 100%;
				height: auto;
				border-radius: 8px;
			}

			/* 列表 - 参考 Zenn .znc ul/ol */
			.prose :global(ul),
			.prose :global(ol) {
				margin: 1.4rem 0;
				line-height: 1.7;
			}
			.prose :global(ul) {
				padding-left: 1.8em;
			}
			.prose :global(ul > li) {
				list-style: disc;
				margin: 0.4rem 0;
			}
			.prose :global(ul > li::marker) {
				font-size: 1.1em;
				color: var(--color-text-subtle);
			}
			.prose :global(ol) {
				padding-left: 1.7em;
			}
			.prose :global(ol > li) {
				list-style: decimal;
				padding-left: 0.2em;
				margin: 0.4rem 0;
			}
			.prose :global(ol > li::marker) {
				color: var(--color-text-subtle);
				font-weight: 600;
				letter-spacing: -0.05em;
			}
			/* 嵌套列表 */
			.prose :global(ul ul),
			.prose :global(ul ol),
			.prose :global(ol ul),
			.prose :global(ol ol) {
				margin: 0.2em 0;
			}

			/* 表格 - 参考 Zenn .znc table */
			.prose :global(table) {
				margin: 1.2rem auto;
				width: auto;
				border-collapse: collapse;
				font-size: 0.95em;
				line-height: 1.5;
				word-break: normal;
				display: block;
				overflow: auto;
				-webkit-overflow-scrolling: touch;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.5rem;
				border: 1px solid var(--color-border);
			}
			.prose :global(th) {
				font-weight: 700;
				background: var(--color-bg-dim);
			}
			.prose :global(td) {
				background: #fff;
			}

			/* 行内代码 - 参考 Zenn .znc code */
			.prose :global(code) {
				padding: 0.2em 0.4em;
				margin: 0 0.2em;
				background: var(--color-bg-code);
				font-size: 0.85em;
				border-radius: 4px;
				font-family: var(--font-code);
				vertical-align: 0.08em;
				-webkit-font-smoothing: antialiased;
			}

			/* 代码块 - 参考 Zenn .znc pre */
			.prose :global(pre) {
				margin: 1.3rem 0;
				background: var(--color-bg-code-block);
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				border-radius: 4px;
				word-break: normal;
				word-wrap: normal;
				display: flex;
			}
			.prose :global(pre > code) {
				all: unset;
				display: block;
				padding: 1.1rem;
				font-family: var(--font-code);
				font-size: 0.9em;
				color: #fff;
				-webkit-font-smoothing: antialiased;
			}

			/* 引用块 - 参考 Zenn .znc blockquote */
			.prose :global(blockquote) {
				font-size: 0.97em;
				margin: 1.4rem 0;
				border-left: 3px solid var(--color-border-emphasis);
				padding: 2px 0 2px 0.7em;
				color: var(--color-text-subtle);
			}
			.prose :global(blockquote p) {
				margin: 1rem 0;
			}
			.prose :global(blockquote > :first-child) {
				margin-top: 0;
			}
			.prose :global(blockquote > :last-child) {
				margin-bottom: 0;
			}

			/* 分割线 */
			.prose :global(hr) {
				border: none;
				border-top: 1px solid var(--color-border);
				margin: 2.5rem 0;
			}

			/* details/summary - 参考 Zenn .znc details */
			.prose :global(details) {
				font-size: 0.95em;
				margin: 1rem 0;
				line-height: 1.7;
			}
			.prose :global(summary) {
				cursor: pointer;
				outline: 0;
				padding: 0.7em 0.7em 0.7em 0.9em;
				border: 1px solid var(--color-border);
				font-size: 0.9em;
				border-radius: 14px;
			}
			.prose :global(details[open] > summary) {
				border-radius: 14px 14px 0 0;
				background: var(--color-bg-dim);
				border-bottom: none;
			}

			/* mark / kbd / abbr */
			.prose :global(mark) {
				background: rgb(255 220 0 / 35%);
				padding: 0.1em 0.2em;
				border-radius: 2px;
			}
			.prose :global(kbd) {
				padding: 0.15em 0.4em;
				font-size: 0.85em;
				font-family: var(--font-code);
				background: var(--color-bg-dim);
				border: 1px solid var(--color-border);
				border-radius: 4px;
				box-shadow: 0 1px 0 var(--color-border);
			}

			/* 响应式 */
			@media (max-width: 992px) {
				.article-header-inner {
					padding: 3.4rem 40px 3.2rem;
				}
			}
			@media (max-width: 768px) {
				.article-header-inner {
					padding: 2.5rem 25px 2rem;
				}
				.article-header-inner h1 {
					font-size: 1.6em;
				}
				.article-card {
					padding: 2rem 25px;
				}
			}
			@media (max-width: 576px) {
				.article-header-inner {
					padding: 2rem 20px 1.5rem;
				}
				.article-header-inner h1 {
					font-size: 1.5em;
				}
				.article-card {
					padding: 2rem 20px;
					border-radius: 0;
					border-left: none;
					border-right: none;
				}
				.prose :global(h1) { font-size: 1.6em; }
				.prose :global(h2) { font-size: 1.4em; }
				.prose :global(h3) { font-size: 1.2em; }
				.prose :global(pre > code) {
					padding: 1rem 0.8rem;
					font-size: 0.85em;
				}
			}
			@media (max-width: 400px) {
				.article-header-inner {
					padding: 1.5rem 14px 1.2rem;
				}
				.article-card {
					padding: 1.5rem 14px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<!-- 文章标题区 - 大留白，浅灰背景 -->
			<div class="article-header">
				<div class="article-header-inner">
					<h1>{title}</h1>
					<div class="article-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									· 更新于 <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
				</div>
			</div>

			<!-- 文章正文 + TOC 双栏 -->
			<div class="article-outer">
				<div class="columns-container">
					<div class="content-column">
						<div class="article-card">
							<div class="hero-image">
								{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
							</div>
							<div class="prose">
								<slot />
							</div>
						</div>
					</div>
					{headings.length > 0 && (
						<aside class="sidebar-column">
							<TableOfContents headings={headings} />
						</aside>
					)}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;

// 只取 h2 和 h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
	<nav class="toc" aria-label="目录">
		<div class="toc-title">目录</div>
		<ul class="toc-list">
			{tocHeadings.map((heading) => (
				<li class:list={['toc-item', { 'toc-item-h3': heading.depth === 3 }]}>
					<a href={`#${heading.slug}`} data-slug={heading.slug}>
						{heading.text}
					</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc {
		position: sticky;
		top: 1.5rem;
		max-height: calc(100vh - 3rem);
		overflow-y: auto;
		padding: 20px;
		background: var(--color-bg-inner, #fff);
		border: 1px solid var(--color-border-lighter, #e4edf4);
		border-radius: 4px;
		font-size: 14px;
		line-height: 1.5;
	}

	.toc::-webkit-scrollbar {
		width: 4px;
	}
	.toc::-webkit-scrollbar-thumb {
		background: var(--color-border, #d6e3ed);
		border-radius: 4px;
	}

	.toc-title {
		font-size: 16px;
		font-weight: 700;
		letter-spacing: 1px;
		margin-bottom: 0.6rem;
		color: var(--color-text-body, rgb(0 0 0 / 82%));
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		position: relative;
	}

	/* 左侧竖线 - Zenn: left:5px, width:2px */
	.toc-list::before {
		content: '';
		position: absolute;
		top: 17px;
		bottom: 8px;
		left: 5px;
		width: 2px;
		background: #e0efff;
		border-radius: 0 0 5px 5px;
	}

	.toc-item {
		position: relative;
		padding-left: 21px;
		margin-top: 5px;
	}

	/* h2 圆点 - Zenn: 12x12, top:4px, left:0, border:2px */
	.toc-item::before {
		content: '';
		position: absolute;
		top: 4px;
		left: 0;
		width: 12px;
		height: 12px;
		background: #bfdcff;
		border: 2px solid #fff;
		border-radius: 50%;
		transition: background 0.2s, border-color 0.2s;
		box-sizing: border-box;
	}

	/* h2 加粗 */
	.toc-item:not(.toc-item-h3) {
		font-weight: 700;
	}

	/* h3 圆点 - Zenn: 8x8, top:6px, left:2px (居中对齐竖线) */
	.toc-item-h3 {
		font-weight: 400;
	}
	.toc-item-h3::before {
		width: 8px;
		height: 8px;
		top: 6px;
		left: 2px;
		background: #cfe5ff;
	}

	.toc-item a {
		display: block;
		display: -webkit-box;
		max-height: 3.05em;
		overflow: hidden;
		color: var(--color-text-subtle, #65717b);
		text-decoration: none;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		margin: 8px 0;
		transition: color 0.15s;
	}

	.toc-item a:hover,
	.toc-item a.active {
		color: var(--color-text-body, rgb(0 0 0 / 82%));
	}

	/* 激活状态 - h2 圆点变蓝 */
	.toc-item:has(a.active)::before {
		background: #3ea8ff;
		border-color: #e0efff;
	}

	/* 激活状态 - h3 圆点也变蓝 */
	.toc-item-h3:has(a.active)::before {
		background: #3ea8ff;
		border-color: #3ea8ff;
	}
</style>

<script>
	function initToc() {
		const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-item a');
		if (tocLinks.length === 0) return;

		// 收集所有标题元素，按文档顺序
		const headingEls: { el: HTMLElement; link: HTMLAnchorElement }[] = [];
		tocLinks.forEach((link) => {
			const slug = link.dataset.slug;
			if (!slug) return;
			const el = document.getElementById(slug);
			if (el) headingEls.push({ el, link });
		});

		if (headingEls.length === 0) return;

		let currentActive: HTMLAnchorElement | null = null;

		function setActive(link: HTMLAnchorElement) {
			if (currentActive === link) return;
			if (currentActive) currentActive.classList.remove('active');
			link.classList.add('active');
			currentActive = link;
			// 滚动 TOC 让当前项可见
			link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
		}

		// 用滚动位置追踪代替 IntersectionObserver，更准确
		function onScroll() {
			const scrollY = window.scrollY;
			const offset = 80; // 偏移量，标题进入视口顶部多少像素时算"当前"

			// 从后往前找，第一个 scrollY >= heading.top - offset 的就是当前标题
			let activeIndex = 0;
			for (let i = headingEls.length - 1; i >= 0; i--) {
				const rect = headingEls[i].el.getBoundingClientRect();
				const headingTop = rect.top + scrollY;
				if (scrollY >= headingTop - offset) {
					activeIndex = i;
					break;
				}
			}

			setActive(headingEls[activeIndex].link);
		}

		// 节流
		let ticking = false;
		function handleScroll() {
			if (!ticking) {
				requestAnimationFrame(() => {
					onScroll();
					ticking = false;
				});
				ticking = true;
			}
		}

		window.addEventListener('scroll', handleScroll, { passive: true });
		// 初始化
		onScroll();

		// 点击平滑滚动
		tocLinks.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const slug = link.dataset.slug;
				if (!slug) return;
				const target = document.getElementById(slug);
				if (target) {
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
					history.pushState(null, '', `#${slug}`);
					// 立即设置激活状态
					setActive(link);
				}
			});
		});
	}

	// 支持 Astro View Transitions
	initToc();
	document.addEventListener('astro:after-swap', initToc);
</script>
